{
  "name": "nvme_raid_health",
  "command": "./nvme_raid_health.sh",
  "platforms": ["8xB300", "4xGB300"],
  "skip_for_cpu_jobs": false,
  "skip_for_partial_gpu_jobs": false,
  "contexts": ["hc_program"],
  "node_states": ["any"],
  "on_fail": "drain",
  "on_ok": "none",
  "reason_base": "$name",
  "reason_append_details": true,
  "run_in_jail": false,
  "log": "slurm_scripts/$worker.$name.$context.out",
  "need_env": []
}
